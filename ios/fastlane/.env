# Fastlane .env — local overrides
# Copy to .env.local and never commit secrets

# Apple ID (email for altool-based uploads)
# FASTLANE_USER=your@email.com

# App-specific password from appleid.apple.com
# FASTLANE_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Apple Developer Team ID (10 chars, found at developer.apple.com)
# FASTLANE_TEAM_ID=XXXXXXXXXX

# App Store Connect API Key (recommended over password)
# Create at: App Store Connect → Users & Access → Keys
# Path to the .p8 file or JSON key
# FASTLANE_APP_STORE_CONNECT_API_KEY_PATH=./fastlane/apple_auth_key.p8
