# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '15.1'
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'AIBrainIM' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Disable code signing for Pods targets - only the main app binary needs signing
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        build_config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        build_config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        build_config.build_settings['CODE_SIGNING_REQUIRED_FOR_EXTENSIONS'] = 'NO'
        # Empty string means "don't code sign" not "Ad Hoc"
        build_config.build_settings['CODE_SIGN_IDENTITY'] = ''
      end
    end

    # Ensure main app target uses correct signing
    installer.generated_projects.each do |project|
      project.targets.each do |target|
        if target.name == 'AIBrainIM'
          target.build_configurations.each do |config|
            config.build_settings['CODE_SIGN_STYLE'] = 'Automatic'
            config.build_settings['DEVELOPMENT_TEAM'] = ''
          end
        end
      end
    end
  end
end
