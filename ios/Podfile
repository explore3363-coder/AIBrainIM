# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '15.1'
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'AIBrainIM' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )

    # 1. Disable code signing for ALL Pods targets (they are static libs/resources, not signed)
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED_FOR_EXTENSIONS'] = 'NO'
        config.build_settings['CODE_SIGN_IDENTITY'] = '-'
        config.build_settings['PROVISIONING_PROFILE_SPECIFIER'] = ''
      end
    end

    # 2. Fix the main AIBrainIM.xcodeproj to use manual signing with correct profile
    app_project_path = File.join(installer.sandbox.root, '..', 'AIBrainIM.xcodeproj')
    if File.exist?(app_project_path)
      app_project = Xcodeproj::Project.open(app_project_path)
      app_project.targets.each do |target|
        if target.name == 'AIBrainIM'
          target.build_configurations.each do |config|
            config.build_settings['CODE_SIGN_STYLE'] = 'Manual'
            config.build_settings['CODE_SIGN_IDENTITY'] = 'iPhone Distribution: Hong Yang (7S96N8A32U)'
            config.build_settings['PROVISIONING_PROFILE_SPECIFIER'] = 'AIBrainIM-CI-AppStore'
            config.build_settings['DEVELOPMENT_TEAM'] = '7S96N8A32U'
            config.build_settings['CODE_SIGNING_ALLOWED'] = 'YES'
          end
          puts "Applied manual signing to AIBrainIM target"
        end
      end
      app_project.save
    else
      puts "WARNING: AIBrainIM.xcodeproj not found at #{app_project_path}"
    end
  end
end
