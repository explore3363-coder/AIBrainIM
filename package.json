{
  "name": "AIBrainIM",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck",
    "build:sim": "xcodebuild -workspace ios/AIBrainIM.xcworkspace -scheme AIBrainIM -configuration Debug -destination 'platform=iOS Simulator,name=iPhone 17 Pro' build CODE_SIGNING_ALLOWED=NO",
    "build:release": "xcodebuild -workspace ios/AIBrainIM.xcworkspace -scheme AIBrainIM -configuration Release -archivePath ios/builds/AIBrainIM.xcarchive archive",
    "screenshot": "bash scripts/capture-screenshots.sh",
    "pods": "cd ios && pod install && cd ..",
    "validate:testflight": "bash scripts/validate-testflight-inputs.sh",
    "validate:release-config": "node scripts/validate-release-config.mjs",
    "validate:assets": "node scripts/validate-appstore-assets.mjs",
    "sync:release-status": "node scripts/sync-release-status.mjs",
    "test:release": "jest --runInBand --detectOpenHandles __tests__/releaseReadiness.test.ts __tests__/releaseChannel.test.ts __tests__/uploadReleaseEvidence.test.ts __tests__/DashboardScreen.test.tsx __tests__/ProfileScreen.test.tsx __tests__/ProjectLibraryScreen.test.tsx __tests__/UploadScreen.test.tsx",
    "preflight:testflight": "node scripts/preflight-testflight.mjs",
    "validate:trigger-readiness": "node scripts/validate-trigger-readiness.mjs",
    "trigger:testflight": "node scripts/trigger-testflight.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native/new-app-screen": "0.85.2",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-native-document-picker": "^9.3.1",
    "react-native-image-picker": "^8.2.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
